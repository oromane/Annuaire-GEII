# ============================================================
# Configuration Annuaire GEII — Fichier d'exemple
# Copiez ce fichier en .env et renseignez vos valeurs.
# ============================================================

# --- Base de Données ---
DB_HOST=localhost
DB_NAME=annuaire_geii
DB_USER=root
DB_PASS=
DB_PORT=3306

# --- Configuration Email ---
# Mode d'envoi : 'phpmail' (PHP mail() natif) ou 'smtp' (serveur SMTP externe)
MAIL_MODE=phpmail

# Paramètres SMTP (uniquement si MAIL_MODE=smtp)
SMTP_HOST=smtp.votre-serveur.fr
SMTP_PORT=587
SMTP_USER=votre-email@universite.fr
SMTP_PASS=votre-mot-de-passe

# Adresse expéditeur (From)
FROM_EMAIL=noreply@universite.fr

# Adresse de réception des messages de contact et notifications
ADMIN_EMAIL=admin@universite.fr
